{
    "files.exclude": {
        "**/*.rpyc": true,
        "**/*.rpa": true,
        "**/*.rpymc": true,
        "**/cache/": true
    },
    "files.associations": {
        "*.sh.template": "plaintext",
        "*.ps1.template": "plaintext"
    },
    "[plaintext]": {
        "editor.formatOnSave": false,
        "editor.formatOnPaste": false
    },
    "chat.tools.terminal.autoApprove": {
        "dotnet run": true
    }
}